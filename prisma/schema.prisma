generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Image {
  id                Int      @id @default(autoincrement())
  filename          String
  originalName      String
  mimeType          String
  size              Int
  originalBucket    String
  originalObjectKey String
  originalUrl       String
  stickerBucket     String?
  stickerObjectKey  String?
  stickerUrl        String?
  thumbnailUrl      String?
  ocrText           String?
  description       String?
  category          String?
  tags              String?
  status            String   @default("processing")
  errorMessage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([createdAt])
}
